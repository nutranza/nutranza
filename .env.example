# Gmail account used to send contact-form emails.
CONTACT_EMAIL_FROM=your-gmail-address@gmail.com

# Gmail App Password for the account above.
# Use the 16-character App Password generated after enabling 2-Step Verification.
CONTACT_EMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Optional inbox recipient. If empty, CONTACT_EMAIL_FROM will be used.
CONTACT_EMAIL_TO=your-gmail-address@gmail.com
